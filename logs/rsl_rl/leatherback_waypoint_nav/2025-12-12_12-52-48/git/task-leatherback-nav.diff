     )
 
 
+def vertical_velocity_penalty(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    velocity_threshold: float = 0.5,
+) -> torch.Tensor:
+    """Penalize excessive vertical velocity - detects hopping while allowing ramp climbing.
+    
+    On ramps, vertical velocity exists but is moderate and proportional to speed.
+    Hopping creates sudden, high vertical velocity spikes.
+    
+    This penalizes z-velocity above a threshold, allowing gradual ramp climbing
+    but heavily penalizing jumping/hopping behavior.
+    
+    Args:
+        env: The environment instance.
+        asset_cfg: Configuration for the robot asset.
+        velocity_threshold: Z-velocity below this is allowed (for ramps). Defaults to 0.5 m/s.
+        
+    Returns:
+        Tensor of shape (num_envs,) containing the penalty.
+    """
+    asset: RigidObject = env.scene[asset_cfg.name]
+    # World frame z-velocity
+    z_vel = asset.data.root_lin_vel_w[:, 2]
+    # Allow small z-velocity for ramp climbing, penalize excessive velocity (hopping)
+    excess_vel = torch.abs(z_vel) - velocity_threshold
+    return torch.square(torch.clamp(excess_vel, min=0.0))
+
+
+def angular_velocity_xy_penalty(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+) -> torch.Tensor:
+    """Penalize high roll/pitch angular velocity - detects hopping oscillations.
+    
+    This is ramp-friendly because:
+    - Climbing a ramp: gradual pitch change, LOW angular velocity
+    - Hopping/bouncing: rapid pitch/roll oscillations, HIGH angular velocity
+    
+    This directly penalizes the oscillatory behavior of hopping without
+    penalizing static orientation (which would hurt ramp climbing).
+    
+    Returns:
+        Tensor of shape (num_envs,) containing squared roll+pitch angular velocity.
+    """
+    asset: RigidObject = env.scene[asset_cfg.name]
+    # Angular velocity in body frame: [roll_rate, pitch_rate, yaw_rate]
+    ang_vel_b = asset.data.root_ang_vel_b
+    # Penalize roll and pitch rates (indices 0 and 1), not yaw (turning is ok)
+    return torch.sum(torch.square(ang_vel_b[:, :2]), dim=1)
+
+
+def upward_velocity_penalty(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+) -> torch.Tensor:
+    """Penalize only upward (positive z) velocity - catches jumping but not falling.
+    
+    This is useful because:
+    - Hopping requires upward velocity to leave the ground
+    - Falling after a bump is not the robot's "fault"
+    - Ramp climbing has upward velocity, so use with moderate weight
+    
+    Returns:
+        Tensor of shape (num_envs,) containing squared positive z-velocity only.
+    """
+    asset: RigidObject = env.scene[asset_cfg.name]
+    z_vel = asset.data.root_lin_vel_w[:, 2]
+    # Only penalize positive (upward) velocity
+    upward_vel = torch.clamp(z_vel, min=0.0)
+    return torch.square(upward_vel)
+
+
+def wheel_ground_contact_penalty(
+    env: ManagerBasedRLEnv,
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+    sensor_cfg: SceneEntityCfg | None = None,
+) -> torch.Tensor:
+    """Penalize when wheels lose contact with the ground.
+    
+    NOTE: This requires a contact sensor to be configured in the scene.
+    If no sensor is configured, this returns zeros (no penalty).
+    
+    Args:
+        env: The environment instance.
+        asset_cfg: Configuration for the robot asset.
+        sensor_cfg: Configuration for the contact sensor on wheels.
+        
+    Returns:
+        Tensor of shape (num_envs,) with penalty for lost wheel contact.
+    """
+    if sensor_cfg is None:
+        # No contact sensor configured, return zero penalty
+        return torch.zeros(env.num_envs, device=env.device)
+    
+    # Get contact sensor data
+    contact_sensor = env.scene.sensors.get(sensor_cfg.name, None)
+    if contact_sensor is None:
+        return torch.zeros(env.num_envs, device=env.device)
+    
+    # Check if wheels have contact (force > threshold)
+    contact_forces = contact_sensor.data.net_forces_w_history
+    has_contact = torch.any(torch.norm(contact_forces[:, :, :, :3], dim=-1) > 1.0, dim=(1, 2))
+    # Penalty when NO contact (wheels airborne)
+    return (~has_contact).float()
+
